<plist version="1.0">
<dict>
	<key>Label</key>
	<string>com.user.PaperRenamer</string>
	<key>ProgramArguments</key>
	<array>
		<string>/bin/zsh</string>
		<string>-l</string>
		<string>-c</string>
		<string>${HOME}/projects/PaperRenamer/code/PaperRenamer.py</string>
